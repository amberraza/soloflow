# ── Django Backend ──
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
DATABASE_URL=postgres://postgres:postgres@localhost:5432/soloflow

# ── CORS ──
# Comma-separated list of frontend origins allowed
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Stripe (Billing) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AWS SES (Email) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_SOURCE_EMAIL=noreply@soloflow.com

# ── Frontend Vite ──
# Points frontend API calls at your backend
VITE_API_URL=http://localhost:8000
